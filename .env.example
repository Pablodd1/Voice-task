# Environment Variables for LunaBill MVP
# Copy this file to .env and fill in the values

# Node Environment
NODE_ENV=development

# Server Port (Render will override this)
PORT=5000

# JWT Authentication (Generate a strong secret: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here_change_to_a_strong_random_string_in_production
JWT_EXPIRES_IN=24h

# Database Configuration
# For development (SQLite)
DB_PATH=./database/lunabill.db

# For production (PostgreSQL on Render.com)
# DATABASE_URL=postgresql://username:password@host:port/database

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes