# Environment Variables for LunaBill / VoxCollect
# Copy this file to .env and fill in the values

# ========================
# SERVER
# ========================
NODE_ENV=development

# Server Port (Railway overrides this)
PORT=5000

# ========================
# DATABASE
# ========================
# For development (SQLite — auto-created)
DB_PATH=./database/lunabill.db

# For production (Railway PostgreSQL — auto-set by Railway plugin)
# DATABASE_URL=postgresql://postgres:XXX@YYY.railway.internal:5432/railway

# ========================
# AUTHENTICATION
# ========================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRES_IN=24h

# ========================
# AI SERVICE
# ========================
# URL of the Python AI service (Railway sets this automatically for container networking)
# For local dev: http://localhost:5001
# For Railway: http://python-ai-service:5001
AI_SERVICE_URL=http://localhost:5001

# MiniMax API Key — get from platform.minimax.io
# The API key format is: your_key (no prefix needed)
MINIMAX_API_KEY=

# Optional: OpenAI key for Whisper STT (fallback if MiniMax STT unavailable)
# OPENAI_WHISPER_API_KEY=

# ========================
# TWILIO (Voice Calls)
# ========================
# Get from twilio.com (pay-as-you-go account)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ========================
# FREESWITCH (Optional — advanced telephony)
# ========================
# FS_HOST=your_freeswitch_host
# FS_PORT=8021
# FS_PASSWORD=your_freeswitch_password
# FS_CONTEXT=default
# DEFAULT_FROM=+1234567890
